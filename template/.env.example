# Empresa / identidade da aplicação (litoral | fotus)
# Definido automaticamente durante a criação do projeto (npm start no template).
VITE_COMPANY=

# URL do PocketBase (dev: localhost, prod: URL do Container App)
VITE_POCKETBASE_URL=http://localhost:8090

# Application Insights (opcional — sem esta variável, logs vão para o console)
VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxxx;IngestionEndpoint=https://...

# ── PocketBase superusuário ───────────────────────────────────────────────────
# Usado por: npm run pb (criação no 1º start) e npm run pb:oauth (autenticação)
# Em dev: se omitido, os scripts pedem interativamente.
# Em CI/CD: defina como secrets do pipeline.
PB_SUPERUSER_EMAIL=admin@example.com
PB_SUPERUSER_PASSWORD=

# ── Autenticação Microsoft Entra ID ──────────────────────────────────────────
# Usado por: npm run pb:oauth
# Em dev: se omitido, o script pede interativamente.
# Em CI/CD: defina como secrets do pipeline.
# No Azure Portal, registre o Redirect URI no App Registration → Authentication → Web:
#   Dev:  http://localhost:8090/api/oauth2-redirect
#   Prod: https://<seu-container-app>.azurecontainerapps.io/api/oauth2-redirect
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# ── GitHub Actions secrets ────────────────────────────────────────────────────
# Azure Static Web Apps:
#   AZURE_STATIC_WEB_APPS_API_TOKEN=<token>
#
# Azure Container Registry:
#   ACR_LOGIN_SERVER=<registry>.azurecr.io
#   ACR_USERNAME=<username>
#   ACR_PASSWORD=<password>
#
# Azure Container Apps:
#   AZURE_RESOURCE_GROUP=<resource-group>
#   AZURE_CONTAINER_APP_NAME=<container-app-name>
#   AZURE_CREDENTIALS=<json do az ad sp create-for-rbac --sdk-auth>
